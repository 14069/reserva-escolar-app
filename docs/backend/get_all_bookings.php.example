<?php

// Referencia de estudo.
// Fonte de verdade da implementacao em uso:
// /opt/lampp/htdocs/reserva_escolar_api_v2/get_all_bookings.php

declare(strict_types=1);

header('Content-Type: application/json; charset=utf-8');

require_once __DIR__ . '/auth_guard.php.example';

function respond(int $statusCode, array $payload): never
{
    http_response_code($statusCode);
    echo json_encode($payload, JSON_UNESCAPED_UNICODE);
    exit;
}

function normalize_query_string(mixed $value): string
{
    return trim((string) ($value ?? ''));
}

$requestedSchoolId = (int) ($_GET['school_id'] ?? 0);
$bookingDate = normalize_query_string($_GET['booking_date'] ?? '');

if ($bookingDate !== '' && !preg_match('/^\d{4}-\d{2}-\d{2}$/', $bookingDate)) {
    respond(422, [
        'success' => false,
        'message' => 'Formato de data invalido. Use YYYY-MM-DD.',
    ]);
}

try {
    // Ajuste estas credenciais e, de preferencia, mova para arquivo seguro de config.
    $pdo = new PDO(
        'mysql:host=127.0.0.1;dbname=reserva_escolar_v2;charset=utf8mb4',
        'root',
        '',
        [
            PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
        ]
    );

    $user = auth_require_user($pdo);
    auth_require_role($user, ['technician']);

    $authenticatedSchoolId = (int) ($user['school_id'] ?? 0);
    if ($requestedSchoolId > 0 && $requestedSchoolId !== $authenticatedSchoolId) {
        respond(403, [
            'success' => false,
            'message' => 'Voce nao pode consultar dados de outra escola.',
        ]);
    }

    $params = ['school_id' => $authenticatedSchoolId];
    $dateCondition = '';
    if ($bookingDate !== '') {
        $dateCondition = ' AND b.booking_date = :booking_date';
        $params['booking_date'] = $bookingDate;
    }

    $bookingsQuery = $pdo->prepare(
        'SELECT
            b.id,
            b.booking_date,
            b.purpose,
            b.status,
            b.cancelled_at,
            r.name AS resource_name,
            u.name AS user_name,
            cg.name AS class_group_name,
            s.name AS subject_name
         FROM bookings b
         INNER JOIN resources r ON r.id = b.resource_id
         INNER JOIN users u ON u.id = b.user_id
         INNER JOIN class_groups cg ON cg.id = b.class_group_id
         INNER JOIN subjects s ON s.id = b.subject_id
         WHERE b.school_id = :school_id' . $dateCondition . '
         ORDER BY b.booking_date DESC, b.id DESC'
    );
    $bookingsQuery->execute($params);

    $bookings = $bookingsQuery->fetchAll();
    if (!$bookings) {
        respond(200, [
            'success' => true,
            'data' => [],
        ]);
    }

    $bookingIds = array_map(
        static fn(array $booking): int => (int) $booking['id'],
        $bookings
    );

    $placeholders = implode(',', array_fill(0, count($bookingIds), '?'));
    $lessonsQuery = $pdo->prepare(
        'SELECT
            bl.booking_id,
            ls.id,
            ls.lesson_number,
            ls.label
         FROM booking_lessons bl
         INNER JOIN lesson_slots ls ON ls.id = bl.lesson_slot_id
         WHERE bl.booking_id IN (' . $placeholders . ')
         ORDER BY ls.lesson_number ASC, ls.id ASC'
    );
    $lessonsQuery->execute($bookingIds);

    $lessonsByBookingId = [];
    foreach ($lessonsQuery->fetchAll() as $lessonRow) {
        $bookingId = (int) $lessonRow['booking_id'];
        $lessonsByBookingId[$bookingId][] = [
            'id' => (int) $lessonRow['id'],
            'lesson_number' => (int) $lessonRow['lesson_number'],
            'label' => (string) $lessonRow['label'],
        ];
    }

    $payload = array_map(
        static function (array $booking) use ($lessonsByBookingId): array {
            $bookingId = (int) $booking['id'];

            return [
                'id' => $bookingId,
                'booking_date' => (string) $booking['booking_date'],
                'purpose' => (string) ($booking['purpose'] ?? ''),
                'status' => (string) ($booking['status'] ?? ''),
                'cancelled_at' => $booking['cancelled_at'],
                'resource_name' => (string) ($booking['resource_name'] ?? ''),
                'user_name' => (string) ($booking['user_name'] ?? ''),
                'class_group_name' => (string) ($booking['class_group_name'] ?? ''),
                'subject_name' => (string) ($booking['subject_name'] ?? ''),
                'lessons' => $lessonsByBookingId[$bookingId] ?? [],
            ];
        },
        $bookings
    );

    respond(200, [
        'success' => true,
        'data' => $payload,
    ]);
} catch (Throwable $exception) {
    respond(500, [
        'success' => false,
        'message' => 'Erro interno ao consultar agendamentos.',
        'debug' => $exception->getMessage(),
    ]);
}
