<?php

// Referencia de estudo.
// Fonte de verdade da implementacao em uso:
// /opt/lampp/htdocs/reserva_escolar_api_v2/login.php

declare(strict_types=1);

header('Content-Type: application/json; charset=utf-8');

function respond(int $statusCode, array $payload): never
{
    http_response_code($statusCode);
    echo json_encode($payload, JSON_UNESCAPED_UNICODE);
    exit;
}

function normalize_string(mixed $value): string
{
    return trim((string) ($value ?? ''));
}

function require_field(array $input, string $key, string $message): string
{
    $value = normalize_string($input[$key] ?? '');
    if ($value === '') {
        respond(422, [
            'success' => false,
            'message' => $message,
        ]);
    }

    return $value;
}

$rawBody = file_get_contents('php://input');
$input = json_decode($rawBody ?: '{}', true);

if (!is_array($input)) {
    respond(400, [
        'success' => false,
        'message' => 'Corpo da requisicao invalido.',
    ]);
}

$schoolCode = strtoupper(require_field($input, 'school_code', 'Informe o codigo da escola.'));
$email = strtolower(require_field($input, 'email', 'Informe o email.'));
$password = require_field($input, 'password', 'Informe a senha.');

try {
    // Ajuste estas credenciais e, de preferencia, mova para arquivo seguro de config.
    $pdo = new PDO(
        'mysql:host=127.0.0.1;dbname=reserva_escolar_v2;charset=utf8mb4',
        'root',
        '',
        [
            PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
        ]
    );

    $query = $pdo->prepare(
        'SELECT
            u.id,
            u.school_id,
            u.name,
            u.email,
            u.role,
            u.password_hash,
            u.is_active,
            s.name AS school_name,
            s.school_code
         FROM users u
         INNER JOIN schools s ON s.id = u.school_id
         WHERE s.school_code = :school_code
           AND u.email = :email
         LIMIT 1'
    );
    $query->execute([
        'school_code' => $schoolCode,
        'email' => $email,
    ]);

    $user = $query->fetch();
    if (!$user) {
        respond(401, [
            'success' => false,
            'message' => 'Codigo da escola, email ou senha invalidos.',
        ]);
    }

    if ((int) ($user['is_active'] ?? 0) !== 1) {
        respond(403, [
            'success' => false,
            'message' => 'Este usuario esta inativo.',
        ]);
    }

    if (!password_verify($password, (string) $user['password_hash'])) {
        respond(401, [
            'success' => false,
            'message' => 'Codigo da escola, email ou senha invalidos.',
        ]);
    }

    $token = bin2hex(random_bytes(32));
    $expiresAt = (new DateTimeImmutable('+12 hours'))->format('Y-m-d H:i:s');

    $tokenUpdate = $pdo->prepare(
        'UPDATE users
         SET api_token = :api_token,
             api_token_expires_at = :api_token_expires_at
         WHERE id = :id'
    );
    $tokenUpdate->execute([
        'api_token' => $token,
        'api_token_expires_at' => $expiresAt,
        'id' => $user['id'],
    ]);

    respond(200, [
        'success' => true,
        'message' => 'Login realizado com sucesso.',
        'data' => [
            'id' => (int) $user['id'],
            'school_id' => (int) $user['school_id'],
            'name' => (string) $user['name'],
            'email' => (string) $user['email'],
            'role' => (string) $user['role'],
            'school_name' => (string) $user['school_name'],
            'school_code' => (string) $user['school_code'],
            'api_token' => $token,
            'api_token_expires_at' => $expiresAt,
        ],
    ]);
} catch (Throwable $exception) {
    respond(500, [
        'success' => false,
        'message' => 'Erro interno ao realizar login.',
        'debug' => $exception->getMessage(),
    ]);
}
