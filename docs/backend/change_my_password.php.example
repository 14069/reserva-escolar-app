<?php

// Referencia de estudo.
// Fonte de verdade da implementacao em uso:
// /opt/lampp/htdocs/reserva_escolar_api_v2/change_my_password.php

declare(strict_types=1);

header('Content-Type: application/json; charset=utf-8');

require_once __DIR__ . '/auth_guard.php.example';

function respond(int $statusCode, array $payload): never
{
    http_response_code($statusCode);
    echo json_encode($payload, JSON_UNESCAPED_UNICODE);
    exit;
}

function normalize_string(mixed $value): string
{
    return trim((string) ($value ?? ''));
}

function require_field(array $input, string $key, string $message): string
{
    $value = normalize_string($input[$key] ?? '');
    if ($value === '') {
        respond(422, [
            'success' => false,
            'message' => $message,
        ]);
    }

    return $value;
}

$rawBody = file_get_contents('php://input');
$input = json_decode($rawBody ?: '{}', true);

if (!is_array($input)) {
    respond(400, [
        'success' => false,
        'message' => 'Corpo da requisicao invalido.',
    ]);
}

$schoolId = (int) ($input['school_id'] ?? 0);
$userId = (int) ($input['user_id'] ?? 0);
$currentPassword = require_field($input, 'current_password', 'Informe a senha atual.');
$newPassword = require_field($input, 'new_password', 'Informe a nova senha.');

if ($schoolId <= 0 || $userId <= 0) {
    respond(422, [
        'success' => false,
        'message' => 'Identificacao do usuario invalida.',
    ]);
}

if (mb_strlen($newPassword) < 6) {
    respond(422, [
        'success' => false,
        'message' => 'A nova senha deve ter pelo menos 6 caracteres.',
    ]);
}

try {
    $pdo = new PDO(
        'mysql:host=127.0.0.1;dbname=reserva_escolar_v2;charset=utf8mb4',
        'root',
        '',
        [
            PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
        ]
    );

    $authenticatedUser = auth_require_user($pdo);

    if ((int) $authenticatedUser['id'] !== $userId || (int) $authenticatedUser['school_id'] !== $schoolId) {
        respond(403, [
            'success' => false,
            'message' => 'Voce nao tem permissao para alterar esta senha.',
        ]);
    }

    $query = $pdo->prepare(
        'SELECT id, school_id, password_hash
         FROM users
         WHERE id = :id
           AND school_id = :school_id
           AND is_active = 1
         LIMIT 1'
    );
    $query->execute([
        'id' => $userId,
        'school_id' => $schoolId,
    ]);

    $user = $query->fetch();
    if (!$user) {
        respond(404, [
            'success' => false,
            'message' => 'Usuario nao encontrado.',
        ]);
    }

    if (!password_verify($currentPassword, (string) $user['password_hash'])) {
        respond(401, [
            'success' => false,
            'message' => 'A senha atual informada nao confere.',
        ]);
    }

    if (password_verify($newPassword, (string) $user['password_hash'])) {
        respond(422, [
            'success' => false,
            'message' => 'A nova senha deve ser diferente da atual.',
        ]);
    }

    $newPasswordHash = password_hash($newPassword, PASSWORD_DEFAULT);

    $update = $pdo->prepare(
        'UPDATE users
         SET password_hash = :password_hash
         WHERE id = :id
           AND school_id = :school_id'
    );
    $update->execute([
        'password_hash' => $newPasswordHash,
        'id' => $userId,
        'school_id' => $schoolId,
    ]);

    respond(200, [
        'success' => true,
        'message' => 'Senha atualizada com sucesso.',
    ]);
} catch (Throwable $exception) {
    respond(500, [
        'success' => false,
        'message' => 'Erro interno ao atualizar a senha.',
        'debug' => $exception->getMessage(),
    ]);
}
