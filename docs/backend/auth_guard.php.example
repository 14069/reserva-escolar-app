<?php

// Referencia de estudo.
// Na API real em uso, a autenticacao esta centralizada em:
// /opt/lampp/htdocs/reserva_escolar_api_v2/response.php

declare(strict_types=1);

function auth_respond(int $statusCode, array $payload): never
{
    http_response_code($statusCode);
    echo json_encode($payload, JSON_UNESCAPED_UNICODE);
    exit;
}

function auth_extract_bearer_token(): string
{
    $header = $_SERVER['HTTP_AUTHORIZATION'] ?? $_SERVER['Authorization'] ?? '';
    if (!is_string($header) || $header === '') {
        auth_respond(401, [
            'success' => false,
            'message' => 'Token de autenticacao nao informado.',
        ]);
    }

    if (!preg_match('/Bearer\s+(.+)/i', $header, $matches)) {
        auth_respond(401, [
            'success' => false,
            'message' => 'Formato do token de autenticacao invalido.',
        ]);
    }

    return trim($matches[1]);
}

function auth_require_user(PDO $pdo): array
{
    $token = auth_extract_bearer_token();

    $query = $pdo->prepare(
        'SELECT
            u.id,
            u.school_id,
            u.name,
            u.email,
            u.role,
            u.api_token,
            u.api_token_expires_at,
            s.name AS school_name,
            s.school_code
         FROM users u
         INNER JOIN schools s ON s.id = u.school_id
         WHERE u.api_token = :api_token
           AND u.is_active = 1
         LIMIT 1'
    );
    $query->execute(['api_token' => $token]);

    $user = $query->fetch(PDO::FETCH_ASSOC);
    if (!$user) {
        auth_respond(401, [
            'success' => false,
            'message' => 'Token de autenticacao invalido.',
        ]);
    }

    $expiresAt = (string) ($user['api_token_expires_at'] ?? '');
    if ($expiresAt === '' || strtotime($expiresAt) === false) {
        auth_respond(401, [
            'success' => false,
            'message' => 'Token de autenticacao expirado.',
        ]);
    }

    if (strtotime($expiresAt) < time()) {
        auth_respond(401, [
            'success' => false,
            'message' => 'Token de autenticacao expirado.',
        ]);
    }

    return $user;
}

function auth_require_role(array $user, array $allowedRoles): void
{
    if (!in_array($user['role'] ?? '', $allowedRoles, true)) {
        auth_respond(403, [
            'success' => false,
            'message' => 'Voce nao tem permissao para acessar este recurso.',
        ]);
    }
}
