APP_ENV=production
APP_URL=https://api.seudominio.com.br

# Origens separadas por vírgula para o CORS.
RESERVA_ALLOWED_ORIGINS=https://app.seudominio.com.br,https://www.seudominio.com.br

# Opcao recomendada para Supabase.
# Exemplo:
# RESERVA_DB_URL=postgresql://postgres.PROJECT_REF:SUA_SENHA@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
RESERVA_DB_URL=

# Opcao alternativa por variaveis separadas.
RESERVA_DB_DRIVER=pgsql
RESERVA_DB_HOST=aws-0-us-east-1.pooler.supabase.com
RESERVA_DB_PORT=5432
RESERVA_DB_NAME=postgres
RESERVA_DB_USERNAME=postgres.PROJECT_REF
RESERVA_DB_PASSWORD=
RESERVA_DB_SSLMODE=require

# Defaults locais antigos, se quiser continuar rodando em MySQL no XAMPP:
# RESERVA_DB_DRIVER=mysql
# RESERVA_DB_HOST=127.0.0.1
# RESERVA_DB_PORT=3306
# RESERVA_DB_NAME=reserva_escolar_v2
# RESERVA_DB_USERNAME=root
# RESERVA_DB_PASSWORD=
