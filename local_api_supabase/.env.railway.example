APP_ENV=production
APP_URL=https://api.seudominio.com.br

# Liste aqui o frontend em producao e, se quiser, um frontend de homologacao.
RESERVA_ALLOWED_ORIGINS=https://app.seudominio.com.br,https://www.seudominio.com.br

# Use a Session pooler connection string do projeto Supabase hospedado.
RESERVA_DB_URL=postgresql://postgres.PROJECT_REF:SUA_SENHA@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Use este token para proteger o endpoint de lembretes automaticos.
RESERVA_CRON_TOKEN=troque-por-um-token-seguro
